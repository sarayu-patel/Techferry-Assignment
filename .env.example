# Copy this file to .env and fill in the values you need.
# The commentary pipeline reads these at runtime via python-dotenv.

# ── LLM provider ──────────────────────────────────────────────────────────────
# Which LLM to use for generating commentary text.
# Options: "openai" (default) | "gemini" | "anthropic" | "groq"
COMMENTARY_PROVIDER=openai

# Optional: override the model used by the chosen provider.
# Defaults: openai→gpt-4o-mini  gemini→gemini-2.0-flash  anthropic→claude-haiku-4-5  groq→llama-3.3-70b-versatile
# COMMENTARY_MODEL=gpt-4o

# ── API keys ──────────────────────────────────────────────────────────────────
# Only the key for your chosen COMMENTARY_PROVIDER is required.
# If COMMENTARY_TTS_PROVIDER=openai, OPENAI_API_KEY is also needed.

# OpenAI API key  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google Gemini API key  →  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Anthropic API key  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Groq API key (free tier)  →  https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Event detection ───────────────────────────────────────────────────────────
# Maximum number of commentary events per video (most important ones are kept).
# Priority order: possession_change > fast_ball > sprint
COMMENTARY_MAX_EVENTS=15

# Minimum gap (seconds) between any two commentary events.
# Shorter = more commentary, but risk audio overlap.
# Recommended: 3-5 for short videos, 6-8 for long videos.
COMMENTARY_MIN_GAP_SEC=6.30

# ── Output mode ───────────────────────────────────────────────────────────────
# How commentary is added to the output video.
# Options:
#   subtitle  – text burned into the video frames (no extra deps)
#   audio     – TTS audio mixed into the video (requires gTTS/OpenAI + ffmpeg)
#   both      – subtitles AND audio (default)
#   off       – disable commentary entirely
COMMENTARY_MODE=both

# ── TTS provider (only used when COMMENTARY_MODE=audio or both) ───────────────
# Options: "gtts" (default, free Google TTS) | "openai" (OpenAI TTS, higher quality)
COMMENTARY_TTS_PROVIDER=gtts

# ── Subtitle settings ─────────────────────────────────────────────────────────
# How long each subtitle stays on screen (seconds).
SUBTITLE_DURATION_SEC=3.5

# Position: "bottom" or "top"
SUBTITLE_POSITION=bottom